{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 0,
  "modules-left": [
    "custom/power",
    "clock",
    "battery",
    "backlight",
    "tray",
    "pulseaudio",
    "temperature",
    "memory",
    "cpu"
  ],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "custom/menu"
  ],


  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "on-click": "activate",
    "persistent-workspaces": {
    "*":[1,2]
    },
    "format-icons": {
	"active": "вЧП",
	"default": "вЧЛ"
    }
  },


  "custom/menu": {
    "format": "у∞£З",
    "on-click": "rofi -show drun"
  },


  "custom/power": {
	"format" : "пАС ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "~/.config/waybar/power_menu.xml",
		"menu-actions": {
			"shutdown": "systemctl poweroff",
			"reboot": "systemctl reboot",
			"lock": "hyprlock"
		},
},


  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "у±РЛ",
    "interval": 1,
    "format-icons": ["у∞ВО", "у∞БЉ", "у∞Бњ", "у∞ВБ", "у∞Бє"],
    "tooltip": true,
    "tooltip-format-charging": "Battery: {capacity}%\nCharging: {time} until full",
    "tooltip-format-discharging": "Battery: {capacity}%\nDischarging: {time} remaining",
  },


  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "у∞ЦБ ",
    "format-icons": {
      "headphone": "пА• ",
      "hands-free": "пА• ",
      "headset": "пА• ",
      "phone": "пВХ ",
      "portable": "пВХ ",
      "car": "пЖє ",
      "default": [
        "пА¶ ",
        "пАІ ",
        "пА® "
      ]
    },
    "on-click-left": "pavucontrol -t 3",
    "on-click-right": "pactl -- set-sink-mute 0 toggle",
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%"
  },


  "temperature": {
    "format": "{icon}",
    "critical-threshold": 80,
    "format-critical": "<span color='#ff0000'>{icon}</span>",
    "tooltip": true,
    "tooltip-format": "Temperature: {temperatureC}¬∞C",
    "format-icons": "пЛЙ"
  },
  "memory": {
    "format": "оњЕ ",
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.2f}G/{total:0.2f}G"
  },
  "cpu": {
    "format": "оЙ¶ ",
    "tooltip": true
  },
  "clock": {
    "interval": 1,
    "timezone": "Europe/London",
    "format": " {:%H:%M} ",
    "tooltip": true,
    "tooltip-format": "{:L%d/%m/%Y}"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 6
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "tooltip": true,
    "tooltip-format": "Brightness: {percent}%",
    "format-icons": [
      "у∞ГЮ ",
      "у∞ГЭ ",
      "у∞ГЯ ", "у∞Г† "]
  }
}


